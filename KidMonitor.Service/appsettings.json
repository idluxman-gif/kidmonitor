{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Database": {
    "Path": "C:\\ProgramData\\KidMonitor\\kidmonitor.db"
  },
  "Monitoring": {
    "PollIntervalSeconds": 10,
    "TrackedApps": [
      { "ProcessName": "chrome", "DisplayName": "Google Chrome" },
      { "ProcessName": "msedge", "DisplayName": "Microsoft Edge" },
      { "ProcessName": "firefox", "DisplayName": "Firefox" },
      { "ProcessName": "WhatsApp", "DisplayName": "WhatsApp Desktop" },
      { "ProcessName": "YouTube", "DisplayName": "YouTube" }
    ],
    "LanguageDetection": {
      "Enabled": true,
      "WordList": [],
      "AudioEnabled": false,
      "ModelPath": "C:\\ProgramData\\KidMonitor\\ggml-base.bin",
      "GpuMode": "cpu",
      "AudioWindowSeconds": 8
    }
  },
  "Notifications": {
    "AppStartThresholdMinutes": 5,
    "DailySummaryTimeLocal": "20:00"
  },
  "FoulLanguage": {
    "Enabled": true,
    "WordListPath": "C:\\ProgramData\\KidMonitor\\wordlist.txt"
  }
}
