# ─────────────────────────────────────────────────────────────────────────────
# KidMonitor.Api — Required environment variables for staging / production
#
# Copy this file to .env (never commit .env), fill in real values, and set
# each variable in your Railway / Render dashboard under "Variables".
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Full Postgres connection string.
# Railway format:  postgresql://user:password@host:5432/dbname
# Npgsql format:   Host=host;Port=5432;Database=dbname;Username=user;Password=pass
DATABASE_URL=postgresql://kidmonitor:CHANGE_ME@localhost:5432/kidmonitor

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_USE_AT_LEAST_32_CHARS_openssl_rand_base64_48
JWT_ISSUER=KidMonitor.Api
JWT_AUDIENCE=KidMonitor.Clients

# ── ASP.NET Core ──────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
# Railway injects $PORT automatically; this is handled in railway.toml.
# For Render, set ASPNETCORE_URLS=http://+:$PORT in the dashboard.
ASPNETCORE_URLS=http://+:8080

# ── Firebase / FCM (Android push notifications) ───────────────────────────────
# Option A: paste the full service-account JSON as a single-line string.
# Option B: set FIREBASE_CREDENTIAL_FILE to a path mounted in the container.
FIREBASE_CREDENTIAL_JSON=
# FIREBASE_CREDENTIAL_FILE=/run/secrets/firebase-service-account.json

# ── APNs (iOS push notifications) ─────────────────────────────────────────────
# Key ID and Team ID from developer.apple.com > Certificates, Identifiers & Profiles
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=XXXXXXXXXX
# App bundle identifier, e.g. com.example.kidmonitor
APNS_BUNDLE_ID=com.example.kidmonitor
# Option A: paste the .p8 key contents (include -----BEGIN/END PRIVATE KEY----- lines).
APNS_P8_KEY_CONTENT=
# Option B: path to the .p8 file if mounted as a secret/volume.
# APNS_P8_KEY_PATH=/run/secrets/apns-auth-key.p8
# Use sandbox (true) for TestFlight / development; false for App Store production.
APNS_USE_SANDBOX=false
