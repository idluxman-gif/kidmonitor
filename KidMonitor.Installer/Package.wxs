<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
    Name="KidMonitor"
    Manufacturer="KidMonitor"
    Version="1.0.0.0"
    UpgradeCode="A7E3F2B1-C9D0-4E5A-8B6F-1D2E3F4A5B6C"
    Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="KidMonitor" Level="1">
      <ComponentGroupRef Id="ServiceComponents" />
      <ComponentGroupRef Id="TrayComponents" />
      <ComponentGroupRef Id="DataComponents" />
      <ComponentGroupRef Id="ShortcutComponents" />
    </Feature>

    <!-- PIN prompt property (installer UI sets this) -->
    <Property Id="DASHBOARD_PIN" Value="0000" />

    <!-- Custom action: write dashboard PIN to ProgramData appsettings.json -->
    <!-- Runs after InstallFinalize when installing -->
    <CustomAction
      Id="WriteDashboardPin"
      Script="vbscript"
      ScriptSourceFile="WriteDashboardPin.vbs"
      Execute="deferred"
      Impersonate="no"
      Return="ignore" />

    <CustomAction
      Id="SetWriteDashboardPinData"
      Property="WriteDashboardPin"
      Value="[DASHBOARD_PIN]" />

    <InstallExecuteSequence>
      <Custom Action="SetWriteDashboardPinData" Before="WriteDashboardPin" Condition="NOT Installed" />
      <Custom Action="WriteDashboardPin" Before="InstallFinalize" Condition="NOT Installed" />
    </InstallExecuteSequence>

    <!-- Simple UI with PIN prompt -->
    <ui:WixUI Id="WixUI_Minimal" />

  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="KidMonitor" />
    </StandardDirectory>
    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="DATFOLDER" Name="KidMonitor" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="KidMonitor" />
    </StandardDirectory>
  </Fragment>

  <!-- Service binaries -->
  <Fragment>
    <ComponentGroup Id="ServiceComponents" Directory="INSTALLFOLDER">

      <Component Id="ServiceExe" Guid="B1C2D3E4-F5A6-7890-ABCD-EF1234567891" Bitness="always64">
        <File Id="KidMonitorServiceExe"
              Source="$(var.KidMonitor.Service.PublishDir)KidMonitor.Service.exe"
              KeyPath="yes" />

        <!-- Install as auto-start Windows Service using NT SERVICE virtual account (SEC-03) -->
        <ServiceInstall
          Id="ServiceInstall"
          Name="KidMonitorService"
          DisplayName="KidMonitor Parental Service"
          Description="Monitors child PC usage and sends real-time parental alerts."
          Type="ownProcess"
          Start="auto"
          ErrorControl="normal"
          Account="NT SERVICE\KidMonitorService" />

        <ServiceControl
          Id="ServiceControl"
          Name="KidMonitorService"
          Start="install"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />
      </Component>

    </ComponentGroup>
  </Fragment>

  <!-- Tray application -->
  <Fragment>
    <ComponentGroup Id="TrayComponents" Directory="INSTALLFOLDER">

      <Component Id="TrayExe" Guid="F6A7B8C9-D0E1-2345-F012-456789012345" Bitness="always64">
        <File Id="KidMonitorTrayExe"
              Source="$(var.KidMonitor.Tray.PublishDir)KidMonitor.Tray.exe"
              KeyPath="yes" />

        <!-- Auto-start tray for all users on login -->
        <RegistryValue
          Root="HKLM"
          Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Run"
          Name="KidMonitorTray"
          Type="string"
          Value="[INSTALLFOLDER]KidMonitor.Tray.exe" />
      </Component>

    </ComponentGroup>
  </Fragment>

  <!-- Data directory + default config -->
  <Fragment>
    <ComponentGroup Id="DataComponents" Directory="DATFOLDER">

      <!-- Create ProgramData directory -->
      <Component Id="DataDir" Guid="D3E4F5A6-B7C8-9012-CDEF-123456789012">
        <CreateFolder />
      </Component>

      <!-- Default appsettings.json (NeverOverwrite = preserves existing user config) -->
      <Component Id="AppSettings" Guid="C2D3E4F5-A6B7-8901-BCDE-F12345678902" NeverOverwrite="yes">
        <File Id="AppSettingsJson"
              Source="..\KidMonitor.Service\appsettings.json"
              KeyPath="yes" />
      </Component>

      <!-- Default word list placeholder -->
      <Component Id="WordList" Guid="E4F5A6B7-C8D9-0123-DEF0-234567890123" NeverOverwrite="yes">
        <File Id="WordListTxt"
              Source="wordlist.txt"
              KeyPath="yes" />
      </Component>

    </ComponentGroup>
  </Fragment>

  <!-- Start Menu shortcut -->
  <Fragment>
    <ComponentGroup Id="ShortcutComponents" Directory="ApplicationProgramsFolder">

      <Component Id="DashboardShortcut" Guid="A8B9C0D1-E2F3-4567-A890-BCDEF0123456">
        <!-- Shortcut to open the dashboard in the default browser -->
        <util:InternetShortcut
          Id="DashboardShortcutFile"
          Name="KidMonitor Dashboard"
          Target="http://localhost:5110" />
        <RemoveFolder Id="CleanUpApplicationProgramsFolder" On="uninstall" />
        <RegistryValue
          Root="HKCU"
          Key="Software\KidMonitor"
          Name="installed"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>

    </ComponentGroup>
  </Fragment>

</Wix>
