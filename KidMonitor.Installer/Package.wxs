<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package
    Name="KidMonitor"
    Manufacturer="KidMonitor"
    Version="1.0.0.0"
    UpgradeCode="A7E3F2B1-C9D0-4E5A-8B6F-1D2E3F4A5B6C"
    Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="KidMonitor" Level="1">
      <ComponentGroupRef Id="ServiceComponents" />
      <ComponentGroupRef Id="TrayComponents" />
      <ComponentGroupRef Id="DataComponents" />
      <ComponentGroupRef Id="ShortcutComponents" />
    </Feature>

    <!-- PIN prompt property (installer UI sets this) -->
    <Property Id="DASHBOARD_PIN" Value="0000" />

    <!-- Custom action: write dashboard PIN to ProgramData appsettings.json -->
    <!-- Runs after InstallFinalize when installing -->
    <CustomAction
      Id="WriteDashboardPin"
      Script="vbscript"
      Execute="deferred"
      Impersonate="no"
      Return="ignore">
      <![CDATA[
        Dim pin, configPath, fso, f, content
        pin = Session.Property("CustomActionData")
        If Len(Trim(pin)) = 0 Then pin = "0000"

        configPath = "C:\ProgramData\KidMonitor\appsettings.json"
        Set fso = CreateObject("Scripting.FileSystemObject")

        ' Read existing content if present, otherwise start fresh
        If fso.FileExists(configPath) Then
          Set f = fso.OpenTextFile(configPath, 1)
          content = f.ReadAll
          f.Close
          ' Replace or append Dashboard.Pin value using simple string injection
          ' If Dashboard section exists, replace pin value
          If InStr(content, """Dashboard""") > 0 Then
            ' Replace the Pin value using regex
            Dim re
            Set re = New RegExp
            re.Pattern = "(""Pin""\s*:\s*"")[^""]*("")"
            re.Global = True
            re.IgnoreCase = True
            content = re.Replace(content, "$1" & pin & "$2")
          Else
            ' Append Dashboard section before last }
            Dim lastBrace
            lastBrace = InStrRev(content, "}")
            If lastBrace > 0 Then
              content = Left(content, lastBrace - 1) & _
                ",""Dashboard"":{""Pin"":""" & pin & """,""Port"":5110}}"
            End If
          End If
        Else
          content = "{""Dashboard"":{""Pin"":""" & pin & """,""Port"":5110}}"
        End If

        Set f = fso.OpenTextFile(configPath, 2, True)
        f.Write content
        f.Close
      ]]>
    </CustomAction>

    <CustomAction
      Id="SetWriteDashboardPinData"
      Property="WriteDashboardPin"
      Value="[DASHBOARD_PIN]" />

    <InstallExecuteSequence>
      <Custom Action="SetWriteDashboardPinData" Before="InstallFinalize">NOT Installed</Custom>
      <Custom Action="WriteDashboardPin" After="InstallFinalize">NOT Installed</Custom>
    </InstallExecuteSequence>

    <!-- Simple UI with PIN prompt -->
    <UI>
      <UIRef Id="WixUI_Minimal" />
    </UI>

  </Package>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="KidMonitor" />
      </Directory>
      <Directory Id="CommonAppDataFolder">
        <Directory Id="DATFOLDER" Name="KidMonitor" />
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="KidMonitor" />
      </Directory>
    </Directory>
  </Fragment>

  <!-- Service binaries -->
  <Fragment>
    <ComponentGroup Id="ServiceComponents" Directory="INSTALLFOLDER">

      <Component Id="ServiceExe" Guid="B1C2D3E4-F5A6-7890-ABCD-EF1234567891">
        <File Id="KidMonitorServiceExe"
              Source="$(var.KidMonitor.Service.PublishDir)KidMonitor.Service.exe"
              KeyPath="yes" />

        <!-- Install as auto-start Windows Service using NT SERVICE virtual account (SEC-03) -->
        <ServiceInstall
          Id="ServiceInstall"
          Name="KidMonitorService"
          DisplayName="KidMonitor Parental Service"
          Description="Monitors child PC usage and sends real-time parental alerts."
          Type="ownProcess"
          Start="auto"
          ErrorControl="normal"
          Account="NT SERVICE\KidMonitorService" />

        <ServiceControl
          Id="ServiceControl"
          Name="KidMonitorService"
          Start="install"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />
      </Component>

    </ComponentGroup>
  </Fragment>

  <!-- Tray application -->
  <Fragment>
    <ComponentGroup Id="TrayComponents" Directory="INSTALLFOLDER">

      <Component Id="TrayExe" Guid="F6A7B8C9-D0E1-2345-F012-456789012345">
        <File Id="KidMonitorTrayExe"
              Source="$(var.KidMonitor.Tray.PublishDir)KidMonitor.Tray.exe"
              KeyPath="yes" />

        <!-- Auto-start tray for all users on login -->
        <RegistryValue
          Root="HKLM"
          Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Run"
          Name="KidMonitorTray"
          Type="string"
          Value="[INSTALLFOLDER]KidMonitor.Tray.exe" />
      </Component>

    </ComponentGroup>
  </Fragment>

  <!-- Data directory + default config -->
  <Fragment>
    <ComponentGroup Id="DataComponents" Directory="DATFOLDER">

      <!-- Create ProgramData directory -->
      <Component Id="DataDir" Guid="D3E4F5A6-B7C8-9012-CDEF-123456789012">
        <CreateFolder />
      </Component>

      <!-- Default appsettings.json (NeverOverwrite = preserves existing user config) -->
      <Component Id="AppSettings" Guid="C2D3E4F5-A6B7-8901-BCDE-F12345678902">
        <File Id="AppSettingsJson"
              Source="..\KidMonitor.Service\appsettings.json"
              KeyPath="yes"
              NeverOverwrite="yes" />
      </Component>

      <!-- Default word list placeholder -->
      <Component Id="WordList" Guid="E4F5A6B7-C8D9-0123-DEF0-234567890123">
        <File Id="WordListTxt"
              Source="wordlist.txt"
              KeyPath="yes"
              NeverOverwrite="yes" />
      </Component>

    </ComponentGroup>
  </Fragment>

  <!-- Start Menu shortcut -->
  <Fragment>
    <ComponentGroup Id="ShortcutComponents" Directory="ApplicationProgramsFolder">

      <Component Id="DashboardShortcut" Guid="A8B9C0D1-E2F3-4567-A890-BCDEF0123456">
        <!-- Shortcut to open the dashboard in the default browser -->
        <util:InternetShortcut
          Id="DashboardShortcutFile"
          Name="KidMonitor Dashboard"
          Target="http://localhost:5110" />
        <RemoveFolder Id="CleanUpApplicationProgramsFolder" On="uninstall" />
        <RegistryValue
          Root="HKCU"
          Key="Software\KidMonitor"
          Name="installed"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>

    </ComponentGroup>
  </Fragment>

</Wix>
